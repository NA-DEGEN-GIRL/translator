# Flutter dart-define 환경 변수 예시
# ------------------------------------------------------------------
# 사용법:
#   1) 이 파일을 .env.flutter 로 복사 (cp .env.flutter.example .env.flutter)
#   2) 아래 값을 실제 키로 채운다
#   3) 빌드/실행 시 --dart-define-from-file 로 주입:
#        flutter run   -d chrome  --dart-define-from-file=.env.flutter
#        flutter build web        --release --dart-define-from-file=.env.flutter
#        flutter build apk        --release --split-per-abi --dart-define-from-file=.env.flutter
#
# 주의: --dart-define 으로 키를 내장한 산출물(web/apk)은 키가 추출 가능하다.
#       개인용 빌드에만 사용하고 배포/공개 저장소에 올리지 말 것.
#       (.env.flutter 자체는 .gitignore 에 포함되어 커밋되지 않는다)
# ------------------------------------------------------------------

# [필수] OpenAI API 키 — Ping-Pong 번역/STT/TTS + 역번역·발음 후처리
OPENAI_API_KEY=sk-proj-여기에_키_입력

# [실시간 통역] Google(Gemini) API 키 — gemini-3.5-live-translate-preview
# 미설정 시 실시간 통역만 비활성(앱 설정 시트에서 직접 입력도 가능)
GOOGLE_API_KEY=AIza여기에_키_입력

# [선택] Ping-Pong 웹 WebSocket 프록시 URL (보통 비워둠)
PINGPONG_WS_PROXY_URL=
